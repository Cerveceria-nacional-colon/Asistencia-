<script>
// ===== STATE =====
let employees = JSON.parse(localStorage.getItem('qr_employees') || '[]');
let records = JSON.parse(localStorage.getItem('qr_records') || '[]');
let currentQRData = null;
let scanStream = null;
let scanInterval = null;

// Default employees
if (employees.length === 0) {
  employees = [
    { id: 'EMP-001', name: 'Carlos Martínez', dept: 'Tecnología', role: 'Desarrollador' },
    { id: 'EMP-002', name: 'Ana López', dept: 'RRHH', role: 'Coordinadora' },
    { id: 'EMP-003', name: 'Luis Rodríguez', dept: 'Ventas', role: 'Asesor' },
    { id: 'EMP-004', name: 'María García', dept: 'Finanzas', role: 'Analista' },
  ];
  saveEmployees();
}

function saveEmployees() { localStorage.setItem('qr_employees', JSON.stringify(employees)); }
function saveRecords() { localStorage.setItem('qr_records', JSON.stringify(records)); }

// ===== CLOCK =====
function updateClock() {
  const now = new Date();
  document.getElementById('headerClock').textContent =
    now.toLocaleDateString('es-MX', {weekday:'short',day:'2-digit',month:'short'}) + ' · ' +
    now.toLocaleTimeString('es-MX', {hour:'2-digit',minute:'2-digit',second:'2-digit'});
}
setInterval(updateClock, 1000); updateClock();

// ===== TABS =====
function switchTab(tab) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('panel-' + tab).classList.add('active');
  event.target.classList.add('active');
  if (tab === 'records') { renderTable(); updateStats(); }
  if (tab === 'employees') renderEmployees();
  if (tab !== 'scanner') stopScan();
}

// ===== TOAST =====
function showToast(msg, type = 'success') {
  const t = document.getElementById('toast');
  t.textContent = msg; t.className = 'show ' + type;
  setTimeout(() => { t.className = ''; }, 3000);
}

// ===== QR GENERATION =====
function generateQR() {
  const sesion = document.getElementById('qrSesion').value.trim() || 'Sesión';
  const tipo = document.getElementById('qrTipo').value;
  const expiry = parseInt(document.getElementById('qrExpiry').value) || 60;
  const now = new Date();
  const exp = new Date(now.getTime() + expiry * 60000);

  currentQRData = {
    sesion, tipo,
    created: now.toISOString(),
    expires: exp.toISOString(),
    code: 'QR-' + Date.now()
  };

  const payload = JSON.stringify(currentQRData);
  document.getElementById('qrcode').innerHTML = '';

  new QRCode(document.getElementById('qrcode'), {
    text: payload,
    width: 220, height: 220,
    colorDark: '#000000', colorLight: '#ffffff',
    correctLevel: QRCode.CorrectLevel.M
  });

  document.getElementById('qrPlaceholder').style.display = 'none';
  document.getElementById('qrcode').style.display = 'block';
  document.getElementById('qrLabel').textContent = sesion + ' · ' + tipo.toUpperCase();

  document.getElementById('qrInfo').style.display = 'block';
  document.getElementById('qrInfo').innerHTML =
    `<strong>Sesión:</strong> ${sesion}<br>
     <strong>Tipo:</strong> ${tipo}<br>
     <strong>Generado:</strong> ${now.toLocaleTimeString('es-MX')}<br>
     <strong>Expira:</strong> ${exp.toLocaleTimeString('es-MX')} (${expiry} min)`;

  showToast('✅ QR generado correctamente');
}

function clearQR() {
  currentQRData = null;
  document.getElementById('qrcode').innerHTML = '';
  document.getElementById('qrcode').style.display = 'none';
  document.getElementById('qrPlaceholder').style.display = 'flex';
  document.getElementById('qrLabel').textContent = '';
  document.getElementById('qrInfo').style.display = 'none';
}

function downloadQR() {
  const canvas = document.querySelector('#qrcode canvas');
  if (!canvas) { showToast('Primero genera un QR', 'error'); return; }
  const link = document.createElement('a');
  link.download = 'asistencia-qr.png';
  link.href = canvas.toDataURL();
  link.click();
  showToast('⬇ QR descargado');
}

// ===== SCANNER =====
async function startScan() {
  try {
    const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
    scanStream = stream;
    const video = document.getElementById('preview');
    video.srcObject = stream;
    document.getElementById('scannerPlaceholder').style.display = 'none';
    document.getElementById('scannerBox').style.display = 'block';
    document.getElementById('btnStartScan').style.display = 'none';
    document.getElementById('btnStopScan').style.display = 'block';
    setStatus('Apunta el QR al recuadro...', 'idle');
    scanInterval = setInterval(decodeFrame, 300);
  } catch (e) {
    showToast('No se pudo acceder a la cámara', 'error');
    setStatus('Error al acceder a la cámara', 'error');
  }
}

function stopScan() {
  if (scanStream) { scanStream.getTracks().forEach(t => t.stop()); scanStream = null; }
  if (scanInterval) { clearInterval(scanInterval); scanInterval = null; }
  document.getElementById('scannerPlaceholder').style.display = 'flex';
  document.getElementById('scannerBox').style.display = 'none';
  document.getElementById('btnStartScan').style.display = 'block';
  document.getElementById('btnStopScan').style.display = 'none';
  setStatus('Presiona "Iniciar Cámara" para escanear', 'idle');
}

function decodeFrame() {
  const video = document.getElementById('preview');
  if (!video || video.readyState < 2) return;
  const canvas = document.createElement('canvas');
  canvas.width = video.videoWidth; canvas.height = video.videoHeight;
  const ctx = canvas.getContext('2d');
  ctx.drawImage(video, 0, 0);
  const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
  const code = jsQR(imageData.data, imageData.width, imageData.height);
  if (code) {
    try {
      const data = JSON.parse(code.data);
      if (data.code && data.sesion) {
        processQRScan(data);
        stopScan();
      }
    } catch (e) {
      // not our QR
    }
  }
}

function processQRScan(qrData) {
  const now = new Date();
  if (new Date(qrData.expires) < now) {
    setStatus('❌ Este QR ha expirado', 'error');
    showToast('QR expirado', 'error');
    return;
  }
  // Ask who is scanning (simple prompt for demo)
  const name = prompt('¿Cuál es tu nombre o ID de colaborador?', '');
  if (!name) return;

  const emp = employees.find(e =>
    e.name.toLowerCase().includes(name.toLowerCase()) ||
    e.id.toLowerCase() === name.toLowerCase()
  );

  let tipo = qrData.tipo;
  if (tipo === 'ambos') {
    // Check last record for this person today
    const today = now.toDateString();
    const todayRecords = records.filter(r =>
      r.empName.toLowerCase().includes(name.toLowerCase()) &&
      new Date(r.timestamp).toDateString() === today
    );
    const lastType = todayRecords.length > 0 ? todayRecords[todayRecords.length - 1].tipo : null;
    tipo = lastType === 'entrada' ? 'salida' : 'entrada';
  }

  const record = {
    id: Date.now(),
    empId: emp ? emp.id : 'N/A',
    empName: emp ? emp.name : name,
    dept: emp ? emp.dept : '—',
    tipo,
    sesion: qrData.sesion,
    timestamp: now.toISOString(),
    method: 'qr'
  };

  records.unshift(record);
  saveRecords();

  setStatus(`✅ ${record.tipo.toUpperCase()} registrada: ${record.empName}`, 'success');
  showToast(`✅ ${record.tipo.toUpperCase()} registrada para ${record.empName}`);
  updateStats();
}

function setStatus(msg, type) {
  const el = document.getElementById('scanStatus');
  el.textContent = msg;
  el.className = 'status-banner status-' + type;
}

// ===== MANUAL REGISTER =====
document.getElementById('manualEmp').addEventListener('input', function() {
  const val = this.value.toLowerCase();
  const box = document.getElementById('empSuggest');
  if (val.length < 1) { box.innerHTML = ''; return; }
  const matches = employees.filter(e =>
    e.name.toLowerCase().includes(val) || e.id.toLowerCase().includes(val)
  ).slice(0, 4);
  box.innerHTML = matches.map(e =>
    `<div onclick="selectEmp('${e.name}')" style="cursor:pointer;padding:8px 12px;background:var(--surface2);border:1px solid var(--border);border-radius:6px;margin-bottom:4px;font-size:0.85rem;">
      <strong>${e.name}</strong> <span style="color:var(--muted);">${e.id} · ${e.dept}</span>
    </div>`
  ).join('');
});

function selectEmp(name) {
  document.getElementById('manualEmp').value = name;
  document.getElementById('empSuggest').innerHTML = '';
}

function manualRegister() {
  const name = document.getElementById('manualEmp').value.trim();
  const tipo = document.getElementById('manualTipo').value;
  if (!name) { showToast('Ingresa el nombre del colaborador', 'error'); return; }

  const emp = employees.find(e =>
    e.name.toLowerCase().includes(name.toLowerCase()) ||
    e.id.toLowerCase() === name.toLowerCase()
  );

  const record = {
    id: Date.now(),
    empId: emp ? emp.id : 'N/A',
    empName: emp ? emp.name : name,
    dept: emp ? emp.dept : '—',
    tipo,
    sesion: 'Registro manual',
    timestamp: new Date().toISOString(),
    method: 'manual'
  };

  records.unshift(record);
  saveRecords();
  document.getElementById('manualEmp').value = '';
  showToast(`✅ ${tipo.toUpperCase()} registrada para ${record.empName}`);
  updateStats();
}

// ===== RECORDS TABLE =====
function renderTable() {
  const filter = document.getElementById('filterText').value.toLowerCase();
  const filterDate = document.getElementById('filterDate').value;
  const filterType = document.getElementById('filterType').value;

  let filtered = records.filter(r => {
    const matchText = !filter || r.empName.toLowerCase().includes(filter) || r.empId.toLowerCase().includes(filter);
    const matchDate = !filterDate || r.timestamp.startsWith(filterDate);
    const matchType = !filterType || r.tipo === filterType;
    return matchText && matchDate && matchType;
  });

  const tbody = document.getElementById('recordsBody');
  if (filtered.length === 0) {
    tbody.innerHTML = `<tr><td colspan="8"><div class="empty-state">No hay registros que coincidan</div></td></tr>`;
    return;
  }

  tbody.innerHTML = filtered.map((r, i) => {
    const d = new Date(r.timestamp);
    return `<tr>
      <td style="color:var(--muted);font-family:'Space Mono',monospace;font-size:0.75rem;">${i+1}</td>
      <td><strong>${r.empName}</strong></td>
      <td style="font-family:'Space Mono',monospace;font-size:0.78rem;color:var(--muted);">${r.empId}</td>
      <td style="color:var(--muted);font-size:0.82rem;">${r.dept}</td>
      <td><span class="badge badge-${r.tipo}">${r.tipo.toUpperCase()}</span></td>
      <td style="font-size:0.8rem;color:var(--muted);">${r.sesion}</td>
      <td style="font-family:'Space Mono',monospace;font-size:0.78rem;">${d.toLocaleDateString('es-MX')}</td>
      <td style="font-family:'Space Mono',monospace;font-size:0.78rem;">${d.toLocaleTimeString('es-MX')}</td>
    </tr>`;
  }).join('');
}

function updateStats() {
  const today = new Date().toDateString();
  const todayRecs = records.filter(r => new Date(r.timestamp).toDateString() === today);
  document.getElementById('statTotal').textContent = records.length;
  document.getElementById('statEntradas').textContent = todayRecs.filter(r => r.tipo === 'entrada').length;
  document.getElementById('statSalidas').textContent = todayRecs.filter(r => r.tipo === 'salida').length;
}

function clearRecords() {
  if (!confirm('¿Seguro que deseas borrar todos los registros?')) return;
  records = []; saveRecords(); renderTable(); updateStats();
  showToast('Registros eliminados');
}

function exportCSV() {
  if (records.length === 0) { showToast('No hay registros para exportar', 'error'); return; }
  const headers = ['Nombre', 'ID', 'Departamento', 'Tipo', 'Sesión', 'Fecha', 'Hora', 'Método'];
  const rows = records.map(r => {
    const d = new Date(r.timestamp);
    return [r.empName, r.empId, r.dept, r.tipo, r.sesion,
      d.toLocaleDateString('es-MX'), d.toLocaleTimeString('es-MX'), r.method].join(',');
  });
  const csv = [headers.join(','), ...rows].join('\n');
  const blob = new Blob([csv], { type: 'text/csv' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a'); a.href = url; a.download = 'asistencia.csv'; a.click();
  showToast('⬇ CSV exportado');
}

// ===== EMPLOYEES =====
function renderEmployees() {
  const grid = document.getElementById('empGrid');
  if (employees.length === 0) {
    grid.innerHTML = '<p style="color:var(--muted);">Sin colaboradores registrados.</p>';
    return;
  }
  grid.innerHTML = employees.map((e, i) =>
    `<div class="emp-card">
      <div class="emp-avatar">${e.name.charAt(0)}</div>
      <div>
        <div class="emp-name">${e.name}</div>
        <div class="emp-id">${e.id}</div>
        <div class="emp-dept">${e.dept} · ${e.role}</div>
      </div>
    </div>`
  ).join('');
}

function addEmployee() {
  const name = document.getElementById('newEmpName').value.trim();
  const id = document.getElementById('newEmpId').value.trim();
  const dept = document.getElementById('newEmpDept').value.trim();
  const role = document.getElementById('newEmpRole').value.trim();
  if (!name || !id) { showToast('Nombre e ID son requeridos', 'error'); return; }
  if (employees.find(e => e.id === id)) { showToast('Ya existe un colaborador con ese ID', 'error'); return; }
  employees.push({ id, name, dept: dept || '—', role: role || '—' });
  saveEmployees(); renderEmployees();
  document.getElementById('newEmpName').value = '';
  document.getElementById('newEmpId').value = '';
  document.getElementById('newEmpDept').value = '';
  document.getElementById('newEmpRole').value = '';
  showToast(`✅ ${name} agregado`);
}

// Init
updateStats();
</script>

